{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  labels: [
    'dependencies',
    'renovate',
  ],
  assignees: [
    'furushchev',
  ],
  prConcurrentLimit: 5,
  prHourlyLimit: 2,
  timezone: 'UTC',
  schedule: [
    'before 3am on Monday',
  ],
  separateMinorPatch: true,
  packageRules: [
    {
      matchDatasources: [
        'github-releases',
      ],
      matchPackageNames: [
        'bazelbuild/bazelisk',
      ],
      groupName: 'Bazelisk',
      semanticCommitType: 'build',
      semanticCommitScope: 'bazelisk',
      commitMessageTopic: 'Bazelisk',
      automerge: false,
      major: {
        enabled: true,
      },
      minor: {
        enabled: true,
      },
      patch: {
        enabled: true,
      },
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^Dockerfile\\..*$/',
      ],
      matchStrings: [
        'ARG BAZELISK_VERSION=(?<currentValue>.*?)\\n',
      ],
      datasourceTemplate: 'github-releases',
      depNameTemplate: 'bazelbuild/bazelisk',
      versioningTemplate: 'semver',
    },
  ],
}
